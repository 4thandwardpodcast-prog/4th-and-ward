{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/episodes", "dest": "/episodes.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/totw", "dest": "/totw.html" },
    { "src": "/merch", "dest": "/merch.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
